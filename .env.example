# App
NODE_ENV="development"
# Local dev:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production (Vercel) — use full URL with https:// (bare domain also works in code):
# NEXT_PUBLIC_SITE_URL="https://mojasamesaidi.ir"
NEXT_PUBLIC_SITE_NAME="فروشگاه مجسمه‌سازی سعیدی"
LOG_LEVEL="info"

# Database
# First-time setup (from project folder mojasame-saidi):
#   npm run db:setup
# Health check when dev server is running: http://localhost:3000/api/health/db
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mojasame?schema=public"
# Vercel Postgres / pooled production example:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Auth (session cookie signing — required in production)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-secret"
ADMIN_LOGIN_EMAIL="admin@mojasamesaidi.ir"
ADMIN_LOGIN_PASSWORD="replace-with-strong-admin-password"

# Payments — Zarinpal (https://zarinpal.com)
# Sandbox merchant ID from Zarinpal panel; in dev ZARINPAL_SANDBOX defaults to true
PAYMENT_PROVIDER="zarinpal"
ZARINPAL_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ZARINPAL_SANDBOX="true"
# Optional override; default is {NEXT_PUBLIC_SITE_URL}/api/payments/zarinpal/callback
PAYMENT_CALLBACK_URL="http://localhost:3000/api/payments/zarinpal/callback"
# Production:
# PAYMENT_CALLBACK_URL="https://mojasamesaidi.ir/api/payments/zarinpal/callback"
# ZARINPAL_SANDBOX="false"

# Uploads / storage — local (public/uploads) or cloudinary
UPLOAD_STORAGE_DRIVER="local"
UPLOAD_MAX_IMAGE_MB="5"
NEXT_PUBLIC_UPLOAD_STORAGE_DRIVER="local"
# Cloudinary (when UPLOAD_STORAGE_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="mojasame/products"
# Legacy S3 placeholders
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Observability - optional
SENTRY_DSN=""
VERCEL_ANALYTICS_ID=""
