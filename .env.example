# App
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="فروشگاه مجسمه‌سازی سعیدی"
LOG_LEVEL="info"

# Database
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mojasame_saidi?schema=public"
# Vercel Postgres / pooled production example:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Auth
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-secret"
ADMIN_LOGIN_EMAIL="admin@mojasamesaidi.ir"
ADMIN_LOGIN_PASSWORD="replace-with-strong-admin-password"

# Payments - configure only when the gateway is enabled
PAYMENT_PROVIDER="manual"
ZARINPAL_MERCHANT_ID=""
PAYMENT_CALLBACK_URL="https://mojasamesaidi.ir/checkout/callback"

# Uploads / storage
UPLOAD_STORAGE_DRIVER="local"
UPLOAD_MAX_IMAGE_MB="5"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Observability - optional
SENTRY_DSN=""
VERCEL_ANALYTICS_ID=""
